<Page x:Class="travel_agency_system.Views.Auth.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:travel_agency_system.Views.Auth"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="400"
      Title="LoginPage">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <materialDesign:Card Width="350" 
                         Padding="25" 
                         UniformCornerRadius="15" 
                         materialDesign:ElevationAssist.Elevation="Dp6">
            <StackPanel>
                <materialDesign:PackIcon Kind="AccountCircle" Width="60" Height="60" 
                                     HorizontalAlignment="Center" 
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <TextBlock Text="WELCOME BACK" FontSize="18" FontWeight="ExtraBold" 
                       HorizontalAlignment="Center" Margin="0,10,0,30" 
                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <TextBox x:Name="txtEmail"
                     materialDesign:HintAssist.Hint="Email Address"
                     materialDesign:TextFieldAssist.HasClearButton="True"
                     materialDesign:TextFieldAssist.LeadingIcon="Email"
                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                     Margin="0,0,0,20" />

                <PasswordBox x:Name="txtPassword"
                         materialDesign:HintAssist.Hint="Password"
                         materialDesign:TextFieldAssist.LeadingIcon="Lock"
                         Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                         Margin="0,0,0,30" />

                <Button Content="LOGIN" 
                    Click="BtnLogin_Click"
                    IsDefault="True"
                    Height="45"
                    Style="{StaticResource MaterialDesignRaisedButton}" 
                    Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Don't have an account?" VerticalAlignment="Center" Opacity="0.6"/>
                    <Button Content="Sign Up" 
                        Click="GoToRegister_Click"
                        Padding="5,0"
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="{DynamicResource SecondaryHueMidBrush}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Page>
