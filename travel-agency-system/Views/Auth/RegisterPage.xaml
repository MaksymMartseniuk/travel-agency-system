<Page x:Class="travel_agency_system.Views.Auth.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:travel_agency_system.Views.Auth"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="400"
      Title="RegisterPage">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <materialDesign:Card Width="350" Padding="25" UniformCornerRadius="15" 
                             materialDesign:ElevationAssist.Elevation="Dp6">
            <StackPanel>
                <materialDesign:PackIcon Kind="AccountPlus" Width="50" Height="50" 
                                         HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <TextBlock Text="CREATE ACCOUNT" FontSize="18" FontWeight="ExtraBold" 
                           HorizontalAlignment="Center" Margin="0,10,0,20" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                <TextBox x:Name="txtEmail"
                         materialDesign:HintAssist.Hint="Email Address"
                         materialDesign:TextFieldAssist.LeadingIcon="Email"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         Margin="0,0,0,15" />

                <PasswordBox x:Name="txtPassword"
                             materialDesign:HintAssist.Hint="Password"
                             materialDesign:TextFieldAssist.LeadingIcon="Lock"
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                             Margin="0,0,0,15" />

                <PasswordBox x:Name="txtConfirmPassword"
                             materialDesign:HintAssist.Hint="Confirm Password"
                             materialDesign:TextFieldAssist.LeadingIcon="LockCheck"
                             Style="{StaticResource MaterialDesignFloatingHintPasswordBox}"
                             Margin="0,0,0,25" />

                <Button Content="SIGN UP" 
                        Click="BtnRegister_Click"
                        Height="45"
                        Style="{StaticResource MaterialDesignRaisedButton}" 
                        Margin="0,0,0,10"/>

                <Button Content="Already have an account? Login" 
                        Click="GoToLogin_Click"
                        Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="{DynamicResource SecondaryHueMidBrush}"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Page>