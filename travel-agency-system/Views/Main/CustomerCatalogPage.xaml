<Page x:Class="travel_agency_system.Views.Main.CustomerCatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:travel_agency_system.Views.Main"
      xmlns:conv="clr-namespace:travel_agency_system.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="Tour Catalog" Loaded="Page_Loaded">

    <Page.Resources>
        <conv:ActivitiesToStringConverter x:Key="ActivitiesConverter"/>
    </Page.Resources>

    <materialDesign:DialogHost x:Name="RootDialog" CloseOnClickAway="True">

        <materialDesign:DialogHost.DialogContent>
            <Grid Margin="20">

                <StackPanel x:Name="TopUpPanel" Width="250" Visibility="Collapsed">
                    <TextBlock Text="Top Up Balance" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    <TextBox x:Name="TxtTopUpAmount" 
                             materialDesign:HintAssist.Hint="Enter amount ($)" 
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" 
                             PreviewTextInput="NumberValidationTextBox"
                             FontSize="16" Margin="0,0,0,30"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" 
                                Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,10,0" Foreground="Gray"/>
                        <Button Content="CONFIRM" Click="BtnConfirmTopUp_Click" Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>
                </StackPanel>

                <Grid x:Name="HistoryPanel" Width="550" Height="400" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="My Purchase History" FontSize="20" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidBrush}"/>

                    <DataGrid x:Name="DgHistory" Grid.Row="1"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              materialDesign:DataGridAssist.CellPadding="13 8 8 8" 
                              materialDesign:DataGridAssist.ColumnHeaderPadding="8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="140" FontWeight="Medium"/>
                            <DataGridTextColumn Header="Total Amount" Binding="{Binding Amount, StringFormat={}{0:F2}$}" Width="120" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Tours Count" Binding="{Binding PurchasedTours.Count, StringFormat={}{0} tour(s)}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2" Content="CLOSE" Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}" 
                            Margin="0,15,0,0" HorizontalAlignment="Center" Style="{StaticResource MaterialDesignFlatButton}" Width="100"/>
                </Grid>

            </Grid>
        </materialDesign:DialogHost.DialogContent>

        <Grid Background="{DynamicResource MaterialDesignPaper}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Mode="PrimaryMid" materialDesign:ElevationAssist.Elevation="Dp3" Grid.Row="0">
                <Border Padding="16">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource MaterialDesignToolButton}" Click="BtnHistory_Click" ToolTip="Purchase History" Margin="0,0,15,0">
                                <materialDesign:PackIcon Kind="History" Width="28" Height="28" Foreground="White"/>
                            </Button>
                            <materialDesign:PackIcon Kind="Wallet" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="White"/>
                            <TextBlock x:Name="txtUserBalance" Text="Balance: 0.00$" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="White"/>
                            <Button Style="{StaticResource MaterialDesignToolButton}" Click="BtnTopUp_Click" ToolTip="Top Up Balance" Margin="5,0,0,0">
                                <materialDesign:PackIcon Kind="PlusCircleOutline" Width="28" Height="28" Foreground="#81C784"/>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignToolButton}" Click="BtnLogout_Click" ToolTip="Logout" Margin="15,0,0,0">
                                <materialDesign:PackIcon Kind="Logout" Width="28" Height="28" Foreground="White"/>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Compass" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="AVAILABLE TOURS" FontSize="22" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                        </StackPanel>

                    </DockPanel>
                </Border>
            </materialDesign:ColorZone>

            <materialDesign:Card Grid.Row="1" Margin="20" UniformCornerRadius="10" materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="15,10,15,10" Background="#F8F9FA">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="FilterOutline" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <ComboBox x:Name="CmbFilterCategory" Width="90" Margin="0,0,10,0"
                                          materialDesign:HintAssist.Hint="Filter By"
                                          SelectionChanged="Filter_Changed">
                                    <ComboBoxItem Content="All" IsSelected="True"/>
                                    <ComboBoxItem Content="Price"/>
                                    <ComboBoxItem Content="Date"/>
                                </ComboBox>

                                <TextBox x:Name="TxtMinValue" Width="70" Margin="0,0,10,0"
                                         materialDesign:HintAssist.Hint="From"
                                         TextChanged="FilterText_Changed"/>

                                <TextBox x:Name="TxtMaxValue" Width="70" Margin="0,0,15,0"
                                         materialDesign:HintAssist.Hint="To"
                                         TextChanged="FilterText_Changed"/>

                                <materialDesign:PackIcon Kind="Sort" Width="22" Height="22" Foreground="{DynamicResource PrimaryHueMidBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>

                                <ComboBox x:Name="CmbSortOrder" Width="100" Margin="0,0,10,0"
                                          materialDesign:HintAssist.Hint="Sort Order"
                                          SelectionChanged="Filter_Changed">
                                    <ComboBoxItem Content="Ascending" IsSelected="True"/>
                                    <ComboBoxItem Content="Descending"/>
                                </ComboBox>
                            </StackPanel>

                            <Border Grid.Column="1" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="6" Padding="8,4,8,4" Width="260" materialDesign:ElevationAssist.Elevation="Dp1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Kind="Magnify" Width="22" Height="22" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,8,0"/>

                                    <TextBox x:Name="TxtSearch"
                                             Grid.Column="1"
                                             FontSize="15"
                                             VerticalAlignment="Center"
                                             materialDesign:HintAssist.Hint="Search by name, desc, price..."
                                             materialDesign:TextFieldAssist.DecorationVisibility="Hidden"
                                             BorderThickness="0"
                                             TextChanged="TxtSearch_TextChanged"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="DgTours" Grid.Row="1"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              materialDesign:DataGridAssist.CellPadding="13 8 8 8" 
                              materialDesign:DataGridAssist.ColumnHeaderPadding="8"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" FontSize="15" FontWeight="Medium"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0}$}" Width="90" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryHueMidBrush}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="110"/>
                            <DataGridTextColumn Header="Duration" Binding="{Binding Duration.Days, StringFormat={}{0} days}" Width="100"/>
                            <DataGridTemplateColumn Header="Activities" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Activities, Converter={StaticResource ActivitiesConverter}}" 
                                                   TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12" Opacity="0.8"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <Button Grid.Row="2" x:Name="BtnBookSelected" Content="BOOK SELECTED TOUR" 
                    Margin="20,0,20,20" Height="50" Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                    Click="BtnBookSelected_Click" materialDesign:ButtonAssist.CornerRadius="10"/>
        </Grid>
    </materialDesign:DialogHost>
</Page>